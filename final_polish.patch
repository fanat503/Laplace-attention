+    def _hla_flex(self, flex):
+        cfg = GPTConfig(block_size=64, vocab_size=256, n_layer=1, n_head=2,
+                        n_embd=32, gradient_checkpointing=False,
+                        phase_mult=0.15, use_laplace=True, laplace_alpha=1.0,
+                        range_flex=flex)
+        return GPT(cfg)
