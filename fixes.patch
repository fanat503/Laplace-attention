+        stats = hla_statistics(model)
+        assert "mix_k_mean" in stats and "mix_v_mean" in stats
+        # identity init => mix must be exactly 1
+        assert abs(stats["mix_k_mean"] - 1.0) < 1e-6
+        assert abs(stats["mix_v_mean"] - 1.0) < 1e-6
